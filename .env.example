# Copy to .env and fill in your values.
# Never commit .env — it may contain tokens.

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Ports
# ------------------------------------------------------------------------------
PORT=3000
BACKEND_HOST_PORT=3002
FRONTEND_PORT=8080

# ------------------------------------------------------------------------------
# URLs
# ------------------------------------------------------------------------------
BACKEND_PUBLIC_URL=http://localhost:3002
FRONTEND_PUBLIC_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# Vault
# ------------------------------------------------------------------------------
VAULT_ADDR=http://haproxy:8210
VAULT_NAMESPACE=
# VAULT_TOKEN is not needed here — Vault Agent handles auth via AppRole.
# Only set this for local development without the Agent sidecar.
# VAULT_TOKEN=

# ------------------------------------------------------------------------------
# Couchbase (resolved via shared_infra / malware_scan_default network)
# ------------------------------------------------------------------------------
COUCHBASE_CONNSTR=couchbase://couchbase
COUCHBASE_BUCKET=library
COUCHBASE_SCOPE=library_scope

# ------------------------------------------------------------------------------
# Ollama (resolved via shared_infra / malware_scan_default network)
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ------------------------------------------------------------------------------
# Docker Hub (used by publish-ui-images.sh and release-all.sh)
# ------------------------------------------------------------------------------
DOCKERHUB_NAMESPACE=repping
