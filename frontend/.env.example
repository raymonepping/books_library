# Frontend environment — copy to .env and adjust.
# VITE_API_URL is used by the dev server only (Vite proxy).
# In production the nginx container proxies /api/ to the backend service.

# Point to the backend during local `npm run dev` (not used in Docker builds)
VITE_API_URL=http://localhost:3002

# Must match backend API_TOKEN — leave empty if token auth is disabled
VITE_API_TOKEN=
