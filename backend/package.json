{
  "name": "bibliotheek-backend",
  "version": "1.0.0",
  "description": "Bibliotheek personal book library — Express backend",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "setup:index": "node scripts/create-vector-index.js",
    "setup:index:local": "COUCHBASE_CONNSTR=couchbase://localhost node --env-file=../.env scripts/create-vector-index.js",
    "enrich:shell": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/enrich.js",
    "enrich": "node scripts/enrich.js",
    "enrich:force": "node scripts/enrich.js --force",
    "enrich:dry": "node scripts/enrich.js --dry-run",
    "enrich:local": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/enrich.js",
    "enrich:local:force": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/enrich.js --force",
    "dedup:local": "COUCHBASE_CONNSTR=couchbase://localhost node --env-file=../.env scripts/dedup-authors.js",
    "fix-genres:local": "COUCHBASE_CONNSTR=couchbase://localhost node --env-file=../.env scripts/fix-genres.js",
    "check:index:local": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/check-index.js",
    "verify:local": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/vector-verify.js",
    "profile:init": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/init-profile.js",
    "fix-series:local": "COUCHBASE_CONNSTR=couchbase://localhost node --env-file=../.env scripts/fix-series-data.js",
    "report:genres:local": "COUCHBASE_CONNSTR=couchbase://localhost node --env-file=../.env scripts/genre-report.js",
    "report:genres:local:save": "COUCHBASE_CONNSTR=couchbase://localhost node --env-file=../.env scripts/genre-report.js --output ../docs/genre-report.md --open",
    "enrich-genres:local": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/enrich.js --genres",
    "enrich-genres:local:force": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/enrich.js --genres --force",
    "enrich-genres:local:dry": "COUCHBASE_CONNSTR=couchbase://localhost OLLAMA_BASE_URL=http://localhost:11434 node --env-file=../.env scripts/enrich.js --genres --dry-run"
  },
  "dependencies": {
    "axios": "1.17.0",
    "cors": "2.8.6",
    "couchbase": "4.7.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "ml-pca": "^4.1.1",
    "morgan": "1.11.0",
    "uuid": "14.0.0",
    "winston": "3.19.0",
    "zod": "4.4.3"
  }
}
