# Backend environment — copy to .env and adjust.
# Credentials (CB_USERNAME, CB_PASSWORD, API keys) are delivered by Vault Agent
# to /vault/secrets/ and are never stored here.

# Vault Agent
VAULT_ADDR=http://haproxy:8210
VAULT_NAMESPACE=
SECRETS_DIR=/vault/secrets

# App
PORT=3000
BACKEND_HOST_PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# Couchbase — non-secret config only (credentials come from Vault Agent)
COUCHBASE_CONNSTR=couchbase://couchbase
COUCHBASE_BUCKET=library
COUCHBASE_SCOPE=library_scope

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# URLs
BACKEND_PUBLIC_URL=http://localhost:3002
FRONTEND_PUBLIC_URL=http://localhost:8080
